# ============================================================
# TMH Platform — Production Environment Variables
# Copy this file, fill in all values, and set them in Railway
# ============================================================

# ── Server ──────────────────────────────────────────────────
# PORT is auto-set by Railway. Do not set manually.
# PORT=3000
NODE_ENV=production
BASE_PATH=/
UPLOADS_DIR=uploads

# ── Database ─────────────────────────────────────────────────
# Auto-injected by Railway when you link the PostgreSQL service.
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Security (REQUIRED — change ALL defaults before launch) ──
# Generate: openssl rand -hex 32
MAJLIS_ENCRYPTION_KEY=REPLACE_WITH_64_CHAR_HEX

# CMS admin login (default: admin / 1234 — MUST change)
CMS_USERNAME=REPLACE_WITH_YOUR_USERNAME
CMS_PIN=REPLACE_WITH_STRONG_PIN

# Admin API key (default: tmh-admin-2026 — MUST change)
# Generate: openssl rand -base64 32
ADMIN_KEY=REPLACE_WITH_RANDOM_STRING

# ── AI / Content Generation ───────────────────────────────────
# Required for Ideation Engine (research + generation + safety review)
ANTHROPIC_API_KEY=sk-ant-...
PERPLEXITY_API_KEY=pplx-...

# ── Email ─────────────────────────────────────────────────────
# Resend — transactional email (application confirmations)
# Sign up at resend.com, verify themiddleeasthustle.com domain
RESEND_API_KEY=re_...

# Beehiiv — newsletter subscriber sync
# Sign up at beehiiv.com, create publication, get API key
BEEHIIV_API_KEY=...
BEEHIIV_PUBLICATION_ID=pub_...

# ── Cloudflare R2 — Media Storage ─────────────────────────────
# Sign up at cloudflare.com, create R2 bucket "tmh-uploads"
# Cloudflare Dashboard → R2 → Manage R2 API Tokens
R2_ACCOUNT_ID=...
R2_ACCESS_KEY_ID=...
R2_SECRET_ACCESS_KEY=...
R2_BUCKET_NAME=tmh-uploads
# Public URL for serving files (enable public access in R2 bucket settings)
R2_PUBLIC_URL=https://pub-REPLACE.r2.dev

# ── Build-time Variables (set under Railway "Build Variables") ─
# These are needed during `vite build`, not at runtime.
# Set them separately in Railway service → Build Variables tab:
#   PORT=3000
#   BASE_PATH=/
#   NODE_ENV=production
